# Live session data (chat history, whiteboard state, exercise progress,
# etc.) shouldn't be tracked by default — there's no reason to version
# every class's transient activity. To deliberately keep one as a reusable
# template, force-add it past this ignore rule:
#   git add -f sessions/my-template.json
sessions/*.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS cruft
.DS_Store
Thumbs.db
